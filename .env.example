# Jupiter API key is optional for lightweight prototyping, but recommended.
JUPITER_API_KEY=
JUPITER_BASE_URL=

# The Jupiter CLI key name created with: jup keys add <name>
JUPITER_KEY_NAME=mykey

# Keep true until the bot has been reviewed with small sizes.
JUPITER_DRY_RUN=true

# Strategy, market, and risk settings.
TRADER_MARKET=SOL
TRADER_EQUITY_USD=1000
TRADER_RISK_PER_TRADE_PCT=0.01
TRADER_DEFAULT_LEVERAGE=2
TRADER_MAX_LEVERAGE=3
TRADER_MAX_WEEKLY_TRADES=10
TRADER_MAX_DAILY_LOSS_PCT=0.03
# Optional override for config/markets.json candle_interval.
# TRADER_CANDLE_MINUTES=30

# Optional overrides. Defaults come from config/markets.json.
# TRADER_PRICE_SOURCE=pyth
# TRADER_PRICE_MINT=
# TRADER_DATA_PATH=data/sol_usd_30m.csv
# TRADER_COINBASE_PRODUCT=SOL-USD
# TRADER_KRAKEN_PAIR=SOLUSD
# TRADER_BINANCE_SYMBOL=SOLUSDT
# TRADER_PYTH_SYMBOL=Crypto.SOL/USD
# TRADER_PYTH_PRICE_ID=ef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d
# TRADER_TRADE_LOG_PATH=data/sol_trades.csv
# TRADER_STATE_PATH=data/sol_state.json
