# Jupiter API key is optional for lightweight prototyping, but recommended.
JUPITER_API_KEY=
JUPITER_BASE_URL=

# The Jupiter CLI key name created with: jup keys add <name>
JUPITER_KEY_NAME=mykey

# Keep true until the bot has been reviewed with small sizes.
JUPITER_DRY_RUN=true

# Strategy and risk settings.
TRADER_EQUITY_USD=1000
TRADER_RISK_PER_TRADE_PCT=0.01
TRADER_DEFAULT_LEVERAGE=2
TRADER_MAX_LEVERAGE=3
TRADER_MAX_WEEKLY_TRADES=10
TRADER_MAX_DAILY_LOSS_PCT=0.03
TRADER_CANDLE_MINUTES=30
